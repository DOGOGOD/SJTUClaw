# ============================================================================
# SJTUClaw 配置文件
# 复制此文件为 .env 并填写实际值：cp .env.example .env
# .env 已在 .gitignore 中排除，切勿将含有真实密钥的 .env 提交到仓库
# ============================================================================

# ============================================================================
# 必需：LLM 服务
# ============================================================================
# API 密钥（OpenAI 兼容接口）。支持 OpenAI / vLLM / Ollama / LM Studio 等
LLM_API_KEY=sk-your-api-key-here
# API 基础地址。OpenAI 官方: https://api.openai.com/v1
LLM_BASE_URL=https://api.openai.com/v1
# 模型名称。如 gpt-4o / gpt-4o-mini / claude-sonnet-4-20250514 / deepseek-chat
LLM_MODEL=gpt-4o

# ============================================================================
# 上下文窗口
# ============================================================================
# 模型的上下文窗口大小（token），默认 32000
# 用于计算有效 token 预算和触发上下文压缩
LLM_CONTEXT_WINDOW=32000

# 上下文利用率上限（0.0 ~ 1.0），默认 0.80
# 当上下文 token 数超过 window * ratio 时触发上下文压力告警，建议执行 /compact
LLM_CONTEXT_USAGE_RATIO=0.80

# 预留输出 token 数，默认 4096
# 从 context_window 中预留给模型输出的空间
LLM_MAX_OUTPUT_TOKENS=4096

# 多轮合并目标比例，默认 0.5
# 上下文触发压缩时，目标将消息 token 数压缩到 input_budget * ratio
LLM_CONSOLIDATION_RATIO=0.50

# ============================================================================
# LLM 调用可靠性与性能
# ============================================================================
# API 调用失败时的最大重试次数，默认 2
# 仅对瞬态错误生效：网络超时、连接重置、429 限流、5xx 服务端错误
# 设为 0 禁用自动重试
LLM_MAX_RETRIES=2

# 重试基础延迟（秒），默认 1.0
# 使用指数退避策略：第 n 次重试延迟 = base_delay * 2^(n-1)
LLM_RETRY_BASE_DELAY=1.0

# 单次 API 请求超时（秒），默认 120
# 防止因网络问题导致的无限等待
LLM_REQUEST_TIMEOUT=120

# ============================================================================
# 上下文压缩 (Compaction)
# ============================================================================
# 消息 token 数超过此值时触发压缩，默认 2000
COMPACT_MAX_MESSAGE_TOKENS=2000

# 压缩时保留最近消息的 token 预算，默认 1000
COMPACT_KEEP_RECENT_TOKENS=1000

# 压缩时至少保留的消息条数，默认 4
# 无论 token 预算如何，始终保留最近 N 条消息不被压缩
COMPACT_KEEP_RECENT_MESSAGES_MIN=4

# 空闲会话自动压缩 TTL（分钟），默认 60
# Session 在此时间内无新消息时，后台自动执行压缩以释放上下文空间
# 设为 0 可禁用空闲压缩
COMPACT_IDLE_TTL_MINUTES=60

# ---- 独立压缩模型（可选）----
# 不配置则复用主模型的 LLM_API_KEY / LLM_BASE_URL / LLM_MODEL
# 配置独立模型可降低压缩成本（例如使用 gpt-4o-mini 替代 gpt-4o）
# COMPACT_LLM_API_KEY=
# COMPACT_LLM_BASE_URL=
# COMPACT_LLM_MODEL=

# ============================================================================
# Agent Loop 配置
# ============================================================================
# 单轮工具调用次数上限，默认 20
# 超过此数量时自动截断并提示模型总结
CLAW_MAX_TOOL_CALLS_PER_TURN=20

# Agent 循环最大迭代次数，默认 15
# 达到上限后强制模型生成无工具最终回答
CLAW_MAX_AGENT_ITERATIONS=15

# ============================================================================
# 原生联网工具（web_search / web_fetch）
# ============================================================================
# 默认启用；设为 false 可完全移除联网工具
WEB_TOOL_ENABLED=true
# 单次请求超时、最大响应体和瞬时故障重试次数
WEB_TIMEOUT_SECONDS=15
WEB_MAX_RESPONSE_BYTES=2097152
WEB_MAX_RETRIES=2
# 可选。配置后 web_search 使用 Tavily，否则使用 DuckDuckGo
# TAVILY_API_KEY=
# 出于 SSRF 防护考虑默认不读取系统代理；确有需要时可显式开启
WEB_TRUST_ENV_PROXY=false

# ============================================================================
# 历史日志
# ============================================================================
# 会话历史日志最大条目数，默认 2000
# 超过上限时自动归档旧条目
HISTORY_MAX_ENTRIES=2000

# ============================================================================
# Heartbeat 心跳监控
# ============================================================================
# 是否启用定期检查 workspace 中 HEARTBEAT.md 的活跃任务，默认启用
HEARTBEAT_ENABLED=true

# 心跳检查间隔（秒），默认 1800（30 分钟）
HEARTBEAT_INTERVAL_S=1800

# 心跳任务触发时，Agent Loop 保留的最近消息条数，默认 8
HEARTBEAT_KEEP_RECENT=8

# ============================================================================
# Gateway HTTP 服务
# ============================================================================
# 仅在使用 python -m claw.gateway 时生效
# Gateway 监听地址，默认 127.0.0.1（仅本机访问）
# 如需局域网访问可设为 0.0.0.0，并必须同时设置 GATEWAY_API_TOKEN
# GATEWAY_HOST=127.0.0.1
# GATEWAY_API_TOKEN=请替换为至少32字符的随机令牌
# GATEWAY_ALLOWED_ORIGINS=http://127.0.0.1:5173

# Gateway 监听端口，默认 8000
# GATEWAY_PORT=8000

# 启动时是否自动打开浏览器访问 Web UI
# GATEWAY_OPEN_BROWSER=false

# ============================================================================
# 网络代理（QQ Bot WebSocket 连接使用）
# ============================================================================
# 按优先级依次尝试：WSS_PROXY → HTTPS_PROXY → ALL_PROXY
# 仅在 QQ Bot 需要穿透公司防火墙/代理时配置
# WSS_PROXY=
# HTTPS_PROXY=
# ALL_PROXY=

# ============================================================================
# QQ 机器人（官方 QQ Bot API v2）
# ============================================================================
# 获取凭证两种方式：
#   1. 扫码获取:  python -m claw.channels.qq_onboard
#   2. 手动创建: 前往 QQ 开放平台 https://q.qq.com 创建机器人应用
#      然后进入开发设置 → 获取 AppID 和 AppSecret（ClientSecret）

# 是否启用 QQ 机器人通道
QQ_ENABLED=false

# QQ Bot AppID（从 QQ 开放平台获取）
QQ_APP_ID=

# QQ Bot ClientSecret（即 AppSecret，从 QQ 开放平台获取）
QQ_CLIENT_SECRET=

# 允许的使用者 QQ OpenID，用英文逗号分隔多个
# 设为 * 允许所有用户（不推荐用于生产环境）
# 示例: QQ_ALLOW_FROM=ABC123,DEF456
# 留空表示拒绝所有用户；生产环境请填写明确的 OpenID，避免使用通配符
QQ_ALLOW_FROM=

# 消息格式：markdown（支持加粗/代码块等）或 plain（纯文本）
QQ_MSG_FORMAT=markdown

# 收到消息时的确认回复（留空则不发送）
# 示例: QQ_ACK_MESSAGE=⏳ 处理中...
# QQ_ACK_MESSAGE=

# QQ 开放平台 Portal 域名，默认 q.qq.com
# 企业内网环境可能需要修改
# QQ_PORTAL_HOST=q.qq.com

# 附件保存目录（留空使用默认 data/media/qq/）
# QQ_MEDIA_DIR=
