# ============================================================================
# SJTUClaw 配置文件
# 复制此文件为 .env 并填写实际值：cp .env.example .env
# ============================================================================

# ---- 必需：LLM 服务 ----
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# ---- 上下文窗口 ----
# 模型的上下文窗口大小（token），默认 32000
LLM_CONTEXT_WINDOW=32000

# 上下文利用率上限（0.0 ~ 1.0），默认 0.80
# 当上下文 token 数超过 window * ratio 时触发压缩
LLM_CONTEXT_USAGE_RATIO=0.80

# 预留的输出 token 数，默认 4096
LLM_MAX_OUTPUT_TOKENS=4096

# 合并目标比例，默认 0.5
# 压缩时目标为 input_budget * ratio
LLM_CONSOLIDATION_RATIO=0.50

# ---- 压缩配置 ----
# 消息 token 数超过此值时触发压缩，默认 2000
COMPACT_MAX_MESSAGE_TOKENS=2000

# 压缩时保留最近消息的 token 预算，默认 1000
COMPACT_KEEP_RECENT_TOKENS=1000

# 压缩时至少保留的消息条数，默认 4
COMPACT_KEEP_RECENT_MESSAGES_MIN=4

# 空闲会话自动压缩 TTL（分钟），默认 0（禁用）
# 设为 60 表示：60 分钟无活动的会话将被自动压缩
COMPACT_IDLE_TTL_MINUTES=0

# ---- 独立压缩模型（可选） ----
# 不配置则复用主模型。配置独立模型可降低成本。
# COMPACT_LLM_API_KEY=
# COMPACT_LLM_BASE_URL=
# COMPACT_LLM_MODEL=

# ---- 历史日志 ----
# history.jsonl 最大条目数，默认 2000
HISTORY_MAX_ENTRIES=2000
